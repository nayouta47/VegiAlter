{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /d/Projects/VegiAlter/.claude/auto-commit.sh",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "[void][System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms'); $n = New-Object System.Windows.Forms.NotifyIcon; $n.Icon = [System.Drawing.SystemIcons]::Information; $n.Visible = $true; $n.ShowBalloonTip(3000, 'Claude Code', 'Plan이 준비되었습니다', [System.Windows.Forms.ToolTipIcon]::Info); Start-Sleep -Milliseconds 3500; $n.Dispose()",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "[void][System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms'); $n = New-Object System.Windows.Forms.NotifyIcon; $n.Icon = [System.Drawing.SystemIcons]::Information; $n.Visible = $true; $n.ShowBalloonTip(3000, 'Claude Code', '작업이 완료되었습니다', [System.Windows.Forms.ToolTipIcon]::Info); Start-Sleep -Milliseconds 3500; $n.Dispose()",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
